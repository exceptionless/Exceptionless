<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>MiniValidation</id>
    <version>0.10.0</version>
    <authors>Damian Edwards</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/DamianEdwards/MiniValidation</projectUrl>
    <description>A minimalist validation library built atop the existing validation features in .NET's `System.ComponentModel.DataAnnotations` namespace.</description>
    <copyright>Copyright © Damian Edwards</copyright>
    <tags>ComponentModel DataAnnotations validation</tags>
    <repository type="git" url="https://github.com/DamianEdwards/MiniValidation" commit="6d7a931bfaeb00919b4172ebe0fba9b681cf2295" />
    <dependencies>
      <group targetFramework="net8.0" />
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.ComponentModel.Annotations" version="5.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>