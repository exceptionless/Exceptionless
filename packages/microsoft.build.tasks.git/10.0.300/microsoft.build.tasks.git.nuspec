        <dependency id="System.IO.Hashing" version="10.0.8" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="System.IO.Hashing" version="10.0.8" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
