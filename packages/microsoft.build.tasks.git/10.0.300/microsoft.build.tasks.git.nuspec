    <icon>Icon.png</icon>
    <projectUrl>https://github.com/dotnet/dotnet</projectUrl>
    <description>MSBuild tasks providing git repository information.</description>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <tags>MSBuild Tasks source control git</tags>
    <serviceable>true</serviceable>
    <repository type="git" url="https://github.com/dotnet/dotnet" commit="caa81fa4971f74880cdab61990cb1b11420939ec" />
