<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Foundatio.AWS</id>
    <version>13.0.1</version>
    <authors>FoundatioFx</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>foundatio-icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/FoundatioFx/Foundatio.AWS</projectUrl>
    <description>Pluggable foundation blocks for building distributed apps.</description>
    <releaseNotes>https://github.com/FoundatioFx/Foundatio.AWS/releases</releaseNotes>
    <copyright>Copyright © 2026 Foundatio.  All rights reserved.</copyright>
    <tags>Queue Messaging Message Bus ServiceBus Locking Lock Distributed File Storage Blob Jobs Metrics Stats Azure Redis StatsD Amazon AWS S3 broker Logging Log SNS SQS</tags>
    <repository type="git" url="https://github.com/FoundatioFx/Foundatio.AWS" commit="82fca2d3b0078aafcbebb0015799f6f3f45dc6d3" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="AWSSDK.CloudWatch" version="4.0.10.1" exclude="Build,Analyzers" />
        <dependency id="AWSSDK.S3" version="4.0.23" exclude="Build,Analyzers" />
        <dependency id="AWSSDK.SQS" version="4.0.2.28" exclude="Build,Analyzers" />
        <dependency id="AWSSDK.SimpleNotificationService" version="4.0.2.30" exclude="Build,Analyzers" />
        <dependency id="Foundatio" version="13.0.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="AWSSDK.CloudWatch" version="4.0.10.1" exclude="Build,Analyzers" />
        <dependency id="AWSSDK.S3" version="4.0.23" exclude="Build,Analyzers" />
        <dependency id="AWSSDK.SQS" version="4.0.2.28" exclude="Build,Analyzers" />
        <dependency id="AWSSDK.SimpleNotificationService" version="4.0.2.30" exclude="Build,Analyzers" />
        <dependency id="Foundatio" version="13.0.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>