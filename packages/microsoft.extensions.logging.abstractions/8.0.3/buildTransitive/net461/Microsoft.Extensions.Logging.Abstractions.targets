<Project InitialTargets="NETStandardCompatError_Microsoft_Extensions_Logging_Abstractions_net462">
  <Target Name="NETStandardCompatError_Microsoft_Extensions_Logging_Abstractions_net462"
          Condition="'$(SuppressTfmSupportBuildWarnings)' == ''">
    <Warning Text="Microsoft.Extensions.Logging.Abstractions 8.0.3 doesn't support $(TargetFramework) and has not been tested with it. Consider upgrading your TargetFramework to net462 or later. You may also set &lt;SuppressTfmSupportBuildWarnings&gt;true&lt;/SuppressTfmSupportBuildWarnings&gt; in the project file to ignore this warning and attempt to run in this unsupported configuration at your own risk." />
  </Target>
</Project>
