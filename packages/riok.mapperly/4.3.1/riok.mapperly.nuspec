<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Riok.Mapperly</id>
    <version>4.3.1</version>
    <authors>Mapperly Contributors, Lars Tönz, Manuel Allenspach</authors>
