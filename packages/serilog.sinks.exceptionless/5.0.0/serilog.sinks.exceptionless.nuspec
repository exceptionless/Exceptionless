<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Serilog.Sinks.Exceptionless</id>
    <version>5.0.0</version>
    <authors>Serilog Contributors,Exceptionless</authors>
    <license type="file">LICENSE.txt</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <icon>serilog-sink-nuget.png</icon>
    <projectUrl>https://github.com/exceptionless/serilog-sinks-exceptionless</projectUrl>
    <description>Exceptionless sink for Serilog</description>
    <releaseNotes>https://github.com/exceptionless/serilog-sinks-exceptionless/releases</releaseNotes>
    <tags>serilog Exceptionless logging</tags>
    <repository type="git" url="https://github.com/exceptionless/serilog-sinks-exceptionless" commit="64bd8594386ac9d6a4f9662613354d587fbde1c6" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="Exceptionless" version="6.0.4" exclude="Build,Analyzers" />
        <dependency id="Serilog" version="4.0.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Exceptionless" version="6.0.4" exclude="Build,Analyzers" />
        <dependency id="Serilog" version="4.0.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="Microsoft.CSharp" targetFramework=".NETFramework4.6.2" />
      <frameworkAssembly assemblyName="System" targetFramework=".NETFramework4.6.2" />
    </frameworkAssemblies>
  </metadata>
</package>