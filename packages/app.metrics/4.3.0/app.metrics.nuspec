<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>App.Metrics</id>
    <version>4.3.0</version>
    <authors>Allan Hardy and Contributors</authors>
    <owners>Allan Hardy and Contributors</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>logo.png</icon>
    <projectUrl>https://app-metrics.io/</projectUrl>
    <description>App Metrics is an open-source .NET Standard library used to record application metrics.</description>
    <copyright>Allan Hardy 2016</copyright>
    <tags>appmetrics metrics apdex meter gauge counter timer histogram</tags>
    <repository type="git" url="git://github.com/AppMetrics/AppMetrics" commit="a31c5243f77a3a4849514a24b0a82ff4aa3b2992" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.1">
        <dependency id="App.Metrics.Core" version="4.3.0" exclude="Build,Analyzers" />
        <dependency id="App.Metrics.Formatters.Json" version="4.3.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="App.Metrics.Core" version="4.3.0" exclude="Build,Analyzers" />
        <dependency id="App.Metrics.Formatters.Json" version="4.3.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>