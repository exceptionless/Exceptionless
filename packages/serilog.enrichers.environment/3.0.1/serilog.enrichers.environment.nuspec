<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Serilog.Enrichers.Environment</id>
    <version>3.0.1</version>
    <authors>Serilog Contributors</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>serilog-enricher-nuget.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/serilog/serilog-enrichers-environment</projectUrl>
    <description>Enrich Serilog log events with properties from System.Environment.</description>
    <tags>serilog machine enricher</tags>
    <repository type="git" url="https://github.com/serilog/serilog-enrichers-environment" commit="00a37b9d83d810c3bb62f17e23d795ef28baa2c3" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="Serilog" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETFramework4.7.1">
        <dependency id="Serilog" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net6.0">
        <dependency id="Serilog" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="Serilog" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Serilog" version="4.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>