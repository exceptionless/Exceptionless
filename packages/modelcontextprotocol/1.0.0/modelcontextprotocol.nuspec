        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="ModelContextProtocol.Core" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Caching.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="ModelContextProtocol.Core" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Caching.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="ModelContextProtocol.Core" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Caching.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="10.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
