    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>Icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://dot.net/</projectUrl>
    <description>Telemetry support for HTTP Client.</description>
