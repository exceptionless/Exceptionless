    <readme>README.md</readme>
    <projectUrl>https://github.com/RehanSaeed/Serilog.Enrichers.Span</projectUrl>
    <description>Enrich Serilog log events with properties from open telemetry spans.</description>
    <releaseNotes>https://github.com/RehanSaeed/Serilog.Enrichers.Span/releases</releaseNotes>
    <copyright>Copyright © Muhammad Rehan Saeed (RehanSaeed.com). All rights Reserved</copyright>
