<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Joonasw.AspNetCore.SecurityHeaders</id>
    <version>6.0.0</version>
    <title>Joonasw.AspNetCore.SecurityHeaders</title>
    <authors>Joonas Westlin</authors>
    <license type="file">LICENSE.txt</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/juunas11/aspnetcore-security-headers</projectUrl>
    <description>Middleware for adding security headers to an ASP.NET Core application. Allows you to easily add Content Security Policy, Strict Transport Security, and Public Key Pins to an app.</description>
    <releaseNotes>Remove support for .NET 6 and 7, add support for 8 and 9.</releaseNotes>
    <copyright>Copyright 2025 Joonas Westlin</copyright>
    <tags>aspnetcore security headers hsts hpkp csp</tags>
    <repository type="git" url="https://github.com/juunas11/aspnetcore-security-headers" branch="refs/heads/master" commit="9f2e9d9f00ad44e00d50eb96874a4f2cf0b31d6f" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="8.0.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Options" version="8.0.2" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="9.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Options" version="9.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net8.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
      <group targetFramework="net9.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
    </frameworkReferences>
  </metadata>
</package>