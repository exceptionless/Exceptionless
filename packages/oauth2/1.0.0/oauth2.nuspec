<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>OAuth2</id>
    <version>1.0.0</version>
    <authors>Constantin Titarenko, Andrew Semack, Blake Niemyjski and others</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>readme.md</readme>
    <projectUrl>https://github.com/titarenko/OAuth2</projectUrl>
    <description>Allows you to perform user authentication via DigitalOcean, Facebook, Foursquare, GitHub, Google, Instagram, LinkedIn, MailRu, Odnoklassniki, Salesforce, Twitter, VK (Vkontakte), Windows Live, Yandex just in two method calls.</description>
    <releaseNotes>https://github.com/titarenko/OAuth2/releases</releaseNotes>
    <tags>OAuth2, OAuth, DigitalOcean, Facebook, Foursquare, GitHub, Google, Instagram, LinkedIn, MailRu, Odnoklassniki, Twitter, VK (Vkontakte), Windows Live, Yandex, VSTS</tags>
    <repository type="git" url="https://github.com/titarenko/OAuth2" commit="8ae36ed7e3d295df09cb4b861fccfcada423f7ce" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="RestSharp" version="114.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="RestSharp" version="114.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="RestSharp" version="114.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>