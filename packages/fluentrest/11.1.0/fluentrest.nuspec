<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>FluentRest</id>
    <version>11.1.0</version>
    <authors>LoreSoft</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>logo.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/loresoft/FluentRest</projectUrl>
    <description>Fluent wrapper over HttpClient to make REST calls easier</description>
    <copyright>Copyright © 2026 LoreSoft</copyright>
    <tags>HTTP HttpClient REST Fluent</tags>
    <repository type="git" url="https://github.com/loresoft/FluentRest" commit="00615364ec83b506753b8439f916d99d50a1a7f5" />
    <dependencies>
      <group targetFramework="net10.0" />
      <group targetFramework="net8.0">
        <dependency id="System.Text.Json" version="10.0.8" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="System.Text.Json" version="10.0.8" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Text.Json" version="10.0.8" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="System.Text.Json" version="10.0.8" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>