{
    "name": "exceptionless",
    "version": "8.0.0",
    "private": true,
    "scripts": {
        "dev": "cross-env NODE_OPTIONS=--trace-warnings vite dev",
        "dev:api": "cross-env API_HTTP=http://localhost:7110 OLDAPP_HTTP=http://localhost:7110 vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "npm run lint:prettier && npm run lint:eslint",
        "lint:eslint": "eslint .",
        "lint:prettier": "prettier --check .",
        "format": "npm run format:prettier && npm run format:eslint",
        "format:eslint": "eslint . --fix",
        "format:prettier": "prettier --write .",
        "generate-models": "node scripts/generate-api.mjs",
        "generate-templates": "swagger-typescript-api generate-templates -o api-templates",
        "test:e2e": "playwright test",
        "test:unit": "vitest run",
        "test": "npm run test:unit -- --run && npm run test:e2e",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "update": "ncu -i",
        "update:shadcn": "npx shadcn-svelte@latest update",
        "update:skills": "npx skills update"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.2",
        "@eslint/compat": "^2.0.5",
        "@eslint/js": "^10.0.1",
        "@iconify-json/lucide": "^1.2.104",
        "@playwright/test": "^1.59.1",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-svelte-csf": "^5.1.2",
        "@storybook/sveltekit": "^10.3.5",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.58.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "@tanstack/eslint-plugin-query": "^5.100.5",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.3.1",
        "@types/eslint": "^9.6.1",
        "@types/node": "^25.6.0",
        "@types/throttle-debounce": "^5.0.2",
        "cross-env": "^10.1.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-storybook": "^10.3.5",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.5.0",
        "jsdom": "^29.1.0",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.3",
        "storybook": "^10.3.5",
        "svelte": "^5.55.5",
        "svelte-check": "^4.4.6",
        "swagger-typescript-api": "^13.7.2",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^7.3.2",
        "vitest": "4.1.5",
        "vitest-websocket-mock": "^0.5.0",
        "zod": "^4.3.6"
    },
    "dependencies": {
        "@exceptionless/browser": "^3.1.0",
        "@exceptionless/fetchclient": "^0.44.0",
        "@internationalized/date": "^3.12.1",
        "@lucide/svelte": "^1.11.0",
        "@stripe/stripe-js": "^9.3.1",
        "@tanstack/svelte-form": "^1.29.1",
        "@tanstack/svelte-query": "^6.1.24",
        "@tanstack/svelte-query-devtools": "^6.1.24",
        "@tanstack/svelte-table": "^9.0.0-alpha.37",
        "@types/d3-scale": "^4.0.9",
        "@types/d3-shape": "^3.1.8",
        "bits-ui": "^2.18.0",
        "clsx": "^2.1.1",
        "d3-scale": "^4.0.2",
        "dompurify": "^3.4.1",
        "kit-query-params": "^0.0.26",
        "layerchart": "^2.0.0-next.59",
        "mode-watcher": "^1.1.0",
        "oidc-client-ts": "^3.5.0",
        "pretty-ms": "^9.3.0",
        "runed": "^0.37.1",
        "shiki": "^4.0.2",
        "svelte-intercom": "^0.0.35",
        "svelte-sonner": "^1.1.1",
        "svelte-time": "^2.1.0",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.4",
        "throttle-debounce": "^5.0.2",
        "tw-animate-css": "^1.4.0"
    },
    "type": "module",
    "overrides": {
        "storybook": "$storybook"
    }
}
