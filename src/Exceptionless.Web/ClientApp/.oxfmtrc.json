{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "endOfLine": "lf",
    "ignorePatterns": [
        ".agents/**",
        ".svelte-kit/**",
        "build/**",
        "dist/**",
        "playwright-report/**",
        "src/lib/features/shared/components/ui/**",
        "src/lib/generated/**",
        "storybook-static/**",
        "test-results/**"
    ],
    "printWidth": 160,
    "singleQuote": true,
    "sortPackageJson": false,
    "sortTailwindcss": {
        "stylesheet": "./src/app.css"
    },
    "svelte": true,
    "trailingComma": "none"
}
