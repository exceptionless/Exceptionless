{
    "name": "@exceptionless/email-templates",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build --config vite.email.config.ts",
        "dev": "vite build --watch --config vite.email.config.ts",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "lint": "npm run lint:prettier && npm run lint:eslint",
        "lint:eslint": "eslint .",
        "lint:prettier": "prettier --check .",
        "format": "npm run format:prettier && npm run format:eslint",
        "format:eslint": "eslint . --fix",
        "format:prettier": "prettier --write .",
        "storybook": "npm run build && storybook dev -p 6008 --no-open",
        "build-storybook": "npm run build && storybook build"
    },
    "dependencies": {
        "@better-svelte-email/components": "2.1.1",
        "@better-svelte-email/server": "2.1.1",
        "svelte": "5.55.9"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@storybook/addon-docs": "10.4.6",
        "@storybook/addon-svelte-csf": "^5.1.2",
        "@storybook/svelte-vite": "10.4.6",
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@types/handlebars": "^4.0.40",
        "@types/node": "^25.9.1",
        "@typescript-eslint/parser": "^8.60.0",
        "cross-env": "^10.1.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.18.0",
        "globals": "^17.6.0",
        "handlebars": "^4.7.8",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^4.0.1",
        "storybook": "10.4.6",
        "svelte-check": "^4.4.8",
        "typescript": "^5.8.0",
        "vite": "6.4.3"
    },
    "engines": {
        "node": ">=20"
    }
}
