@apiUrl = http://localhost:7110/api/v2
@email = admin@exceptionless.test
@password = tester
@clientToken = LhhP1C9gijpSKCslHHCvwdSIz298twx271nTest
@organizationId = 537650f3b77efe23a47914f3
@projectId = 537650f3b77efe23a47914f4
@referenceId = ref123456

### login to test account
# @name login
POST {{apiUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

###

@token = {{login.response.body.$.token}}

### All
# @name allEvents
GET {{apiUrl}}/events?limit=1
Authorization: Bearer {{token}}

###
@eventId = {{allEvents.response.body.$[0].id}}
@stackId = {{allEvents.response.body.$[0].stack_id}}

### By Id
GET {{apiUrl}}/events/{{eventId}}
Authorization: Bearer {{token}}

### By Id With Expected Stack
GET {{apiUrl}}/events/{{eventId}}?expected_stack_id={{stackId}}
Authorization: Bearer {{token}}

### By Organization
GET {{apiUrl}}/events?organization={{organizationId}}
Authorization: Bearer {{token}}

### By Stack
GET {{apiUrl}}/stacks/{{stackId}}/events
Authorization: Bearer {{token}}

### By Project
GET {{apiUrl}}/projects/{{projectId}}/events
Authorization: Bearer {{token}}

### Count
GET {{apiUrl}}/events/count?aggregations=date:(date~month+cardinality:stack+sum:count~1)+cardinality:stack+terms:(first+@include:true)+sum:count~1&filter=(status:open+OR+status:regressed)
Authorization: Bearer {{token}}

### Simple Strings
POST {{apiUrl}}/events?access_token={{clientToken}}
Content-Type: application/json

Event 1
Event 2
Event 3
Event 4

### Post With ReferenceId
POST {{apiUrl}}/events?access_token={{clientToken}}
Content-Type: application/json

{
  "message": "Test with reference id",
  "reference_id": "{{referenceId}}"
}

### Post User Description
POST {{apiUrl}}/events/by-ref/{{referenceId}}/user-description?access_token={{clientToken}}
Content-Type: application/json

{
  "description": "Test Description"
}

### Update Event By ReferenceId
POST {{apiUrl}}/events/by-ref/{{referenceId}}/user-description?access_token={{clientToken}}
Content-Type: application/json

{
  "email_address": "{{email}}",
  "description": "testing reference id"
}

### Post Custom Event
POST {{apiUrl}}/events?access_token={{clientToken}}
Content-Type: application/json

{
  "type": "404",
  "source": "GET /Print",
  "message": null,
  "geo": "40,-70",
  "value": 1,
  "reference_id": "12345678",
  "session_id": "12345",
  "data": {
    "number": 1,
    "decimal": 1.1,
    "string": "test",
    "boolean": false,
    "@user": {
      "identity": "My-User-Identity"
    },
    "@user_description": {
      "email_address": "{{email}}",
      "description": "my custom description"
    }
  }
}

### Post Complex Object Renderer Dogfood Event
# @name postComplexObjectEvent
POST {{apiUrl}}/events?access_token={{clientToken}}
Content-Type: application/json

{
  "type": "log",
  "source": "Complex Object Renderer Dogfood",
  "message": "Reusable mixed-shape payload for legacy and Svelte object renderer parity",
  "reference_id": "complex-object-dogfood-v1",
  "data": {
    "Complex Object Dogfood": {
      "primitives": {
        "null_value": null,
        "true_value": true,
        "false_value": false,
        "zero": 0,
        "positive_integer": 42,
        "negative_integer": -17,
        "decimal": 1234.5678,
        "scientific_number": 1.2e3,
        "empty_string": "",
        "plain_string": "Exceptionless object rendering",
        "unicode": "Snowman ☃, rocket 🚀, Japanese 例",
        "multiline": "first line\nsecond line\nthird line",
        "iso_date_string": "2026-07-10T15:30:45.123Z",
        "guid_string": "6f9619ff-8b86-d011-b42d-00cf4fc964ff",
        "url_string": "https://example.test/path?alpha=1&beta=two",
        "html_like_text": "<script>window.rendererDogfood = 'must stay text';</script>"
      },
      "empty_containers": {
        "empty_object": {},
        "empty_array": []
      },
      "arrays": {
        "numbers": [0, 1, -2, 3.14159, 1000000],
        "strings": ["alpha", "", "line one\nline two", "<strong>not markup</strong>"],
        "mixed": [null, true, false, 0, "text", { "nested": "object" }, ["nested", "array"]],
        "objects": [
          { "id": 1, "name": "first", "enabled": true },
          { "id": 2, "name": "second", "enabled": false, "metadata": { "score": 9.5 } }
        ]
      },
      "deep_object": {
        "level_1": {
          "level_2": {
            "level_3": {
              "level_4": {
                "level_5": {
                  "leaf": "deep value",
                  "nullable_leaf": null,
                  "leaf_array": [1, { "two": [3, 4] }]
                }
              }
            }
          }
        }
      },
      "unusual_keys": {
        "key with spaces": "spaces",
        "dotted.key": "dot",
        "slash/key": "slash",
        "colon:key": "colon",
        "@symbol_key": "at sign"
      }
    }
  }
}

### Find Complex Object Renderer Dogfood Event
GET {{apiUrl}}/events/by-ref/complex-object-dogfood-v1
Authorization: Bearer {{token}}

### GET Submit Random Parameters
GET {{apiUrl}}/events/submit?access_token={{clientToken}}&foo=bar&edit=&spam=eggs=ham&tags=blue&tags=red&message=foo

### Raygun Post
POST {{apiUrl}}/events?access_token={{clientToken}}
Content-Type: application/json
X-ApiKey: {{clientToken}}

Event 1

### Sessions - Get session count with stats and chart aggregations
GET {{apiUrl}}/organizations/{{organizationId}}/events/count?filter=type:session&aggregations=avg:value+cardinality:user+date:(date^-06:00+cardinality:user)&time=last+7+days
Authorization: Bearer {{token}}

### Sessions - Get session events by session ID
GET {{apiUrl}}/events/sessions/12345?mode=summary
Authorization: Bearer {{token}}

### Sessions - Get sessions list (summary mode)
GET {{apiUrl}}/organizations/{{organizationId}}/events/sessions?mode=summary&limit=10&sort=-date
Authorization: Bearer {{token}}
